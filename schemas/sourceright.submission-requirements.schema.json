{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "../schemas/sourceright.submission-requirements.schema.json",
  "title": "Sourceright submission requirements inventory",
  "type": "object",
  "required": [
    "$schema",
    "schema_version",
    "repo_health_target",
    "generated_for",
    "claim_rule",
    "approval_rule",
    "evidence_gates",
    "self_improving_controls",
    "surfaces"
  ],
  "properties": {
    "$schema": { "const": "../schemas/sourceright.submission-requirements.schema.json" },
    "schema_version": { "const": "sourceright.submission_requirements.v1" },
    "repo_health_target": { "type": "number", "minimum": 9.5 },
    "generated_for": { "type": "string", "minLength": 1 },
    "claim_rule": { "type": "string", "minLength": 1 },
    "approval_rule": { "type": "string", "minLength": 1 },
    "evidence_gates": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 6
    },
    "self_improving_controls": {
      "type": "object",
      "required": [
        "readiness_script",
        "ci_workflow",
        "policy_test",
        "packet_manifest",
        "health_target",
        "agents_and_skills"
      ],
      "additionalProperties": false,
      "properties": {
        "readiness_script": { "type": "string", "minLength": 1 },
        "ci_workflow": { "type": "string", "minLength": 1 },
        "policy_test": { "type": "string", "minLength": 1 },
        "packet_manifest": { "type": "string", "minLength": 1 },
        "health_target": { "type": "string", "minLength": 1 },
        "agents_and_skills": { "type": "string", "minLength": 1 }
      }
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/surface" }
    }
  },
  "$defs": {
    "requirements_source": {
      "type": "object",
      "required": ["label", "kind", "url_or_path", "status"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "url_or_path": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "retrieved_at": { "type": ["string", "null"] }
      }
    },
    "gates": {
      "type": "object",
      "required": [
        "requirements_searched",
        "contracted",
        "hardened_local_package",
        "submission_ready",
        "submitted",
        "publicly_accepted"
      ],
      "additionalProperties": false,
      "properties": {
        "requirements_searched": { "type": "boolean" },
        "contracted": { "type": "boolean" },
        "hardened_local_package": { "type": "boolean" },
        "submission_ready": { "type": "boolean" },
        "submitted": { "type": "boolean" },
        "publicly_accepted": { "type": "boolean" }
      }
    },
    "surface": {
      "type": "object",
      "required": [
        "id",
        "name",
        "category",
        "owning_tracks",
        "current_state",
        "required_artifact",
        "submission_target",
        "requirements_sources",
        "package_contract",
        "gates",
        "approval_required",
        "external_submission_allowed",
        "blockers"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "owning_tracks": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "current_state": { "type": "string", "minLength": 1 },
        "required_artifact": { "type": "string", "minLength": 1 },
        "submission_target": { "type": "string", "minLength": 1 },
        "requirements_sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/requirements_source" },
          "minItems": 1
        },
        "package_contract": { "type": "string", "minLength": 1 },
        "gates": { "$ref": "#/$defs/gates" },
        "approval_required": { "type": "boolean" },
        "external_submission_allowed": { "type": "boolean" },
        "blockers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "maintenance_notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "additionalProperties": false
}
