{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://edithatogo.github.io/sourceright/schemas/sourceright.legal-citation-report.schema.json",
  "title": "Sourceright legal citation report",
  "type": "object",
  "required": ["records", "issues"],
  "additionalProperties": false,
  "properties": {
    "records": {
      "type": "array",
      "items": { "$ref": "#/$defs/record" }
    },
    "issues": {
      "type": "array",
      "items": { "$ref": "#/$defs/issue" }
    }
  },
  "$defs": {
    "record": {
      "type": "object",
      "required": [
        "id",
        "citation_text",
        "citation_type",
        "jurisdiction",
        "court",
        "year",
        "neutral_citation",
        "pinpoint",
        "source_span",
        "providers"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "citation_text": { "type": "string", "minLength": 1 },
        "citation_type": {
          "enum": ["case", "legislation", "regulation", "unknown"]
        },
        "jurisdiction": { "type": ["string", "null"] },
        "court": { "type": ["string", "null"] },
        "year": {
          "anyOf": [
            { "type": "integer", "minimum": 0, "maximum": 65535 },
            { "type": "null" }
          ]
        },
        "neutral_citation": { "type": ["string", "null"] },
        "pinpoint": { "type": ["string", "null"] },
        "source_span": { "type": "string", "minLength": 1 },
        "providers": {
          "type": "array",
          "items": { "$ref": "#/$defs/provider_candidate" }
        }
      }
    },
    "provider_candidate": {
      "type": "object",
      "required": ["provider", "confidence", "identifier", "url"],
      "additionalProperties": false,
      "properties": {
        "provider": {
          "enum": [
            "court_listener",
            "caselaw_access_project",
            "austlii",
            "legislation_register",
            "other"
          ]
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "identifier": { "type": "string" },
        "url": { "type": ["string", "null"] }
      }
    },
    "issue": {
      "type": "object",
      "required": ["issue_type", "citation_text", "message"],
      "additionalProperties": false,
      "properties": {
        "issue_type": {
          "enum": [
            "missing_jurisdiction",
            "missing_year",
            "missing_provider_candidate",
            "ambiguous_citation_type"
          ]
        },
        "citation_text": { "type": "string" },
        "message": { "type": "string", "minLength": 1 }
      }
    }
  }
}
