{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://edithatogo.github.io/sourceright/schemas/sourceright.export-manifest.schema.json",
  "title": "Sourceright export manifest",
  "type": "object",
  "required": ["schema_version", "source", "artifacts"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "sourceright.export_manifest.v1" },
    "source": {
      "type": "object",
      "required": ["references_csl_json"],
      "additionalProperties": false,
      "properties": {
        "references_csl_json": { "type": "string", "minLength": 1 },
        "verification_sidecar_json": { "type": "string" }
      }
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact" }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "required": ["format", "filename"],
      "additionalProperties": false,
      "properties": {
        "format": { "enum": ["yaml", "xml", "ris", "enw", "biblatex"] },
        "filename": { "type": "string", "minLength": 1 },
        "content_type": { "type": "string" },
        "schema_version": { "type": "string" }
      }
    }
  }
}
