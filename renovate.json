{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": false,
  "enabledManagers": [
    "cargo",
    "github-actions",
    "npm"
  ],
  "labels": [
    "dependencies"
  ],
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "assignAutomerge": false,
  "minimumReleaseAge": "3 days",
  "prConcurrentLimit": 1,
  "prHourlyLimit": 1,
  "rangeStrategy": "bump",
  "rebaseWhen": "conflicted",
  "schedule": [
    "before 6am on the first day of the month"
  ],
  "semanticCommits": "enabled",
  "packageRules": [
    {
      "description": "Group routine Rust crate updates separately from Node and Actions updates.",
      "matchManagers": [
        "cargo"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "groupName": "rust crate maintenance",
      "groupSlug": "rust-crate-maintenance",
      "labels": [
        "dependencies",
        "rust"
      ],
      "automerge": true
    },
    {
      "description": "Group MCP and release automation actions so registry plumbing is reviewable as one lane.",
      "matchManagers": [
        "github-actions"
      ],
      "matchPackageNames": [
        "/^actions\\//",
        "/^github\\//",
        "/^docker\\//",
        "/^softprops\\//",
        "/^release-drafter\\//",
        "/^Swatinem\\//"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "groupName": "github actions and mcp release automation",
      "groupSlug": "github-actions-mcp-release-automation",
      "labels": [
        "dependencies",
        "ci",
        "registry"
      ],
      "automerge": true
    },
    {
      "description": "Group docs-site Node modules separately from Rust core updates.",
      "matchManagers": [
        "npm"
      ],
      "matchFileNames": [
        "docs-site/package.json",
        "docs-site/package-lock.json"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "groupName": "docs-site node modules",
      "groupSlug": "docs-site-node-modules",
      "labels": [
        "dependencies",
        "node",
        "docs"
      ],
      "automerge": true
    },
    {
      "description": "Keep major updates separate for review, but still on the monthly schedule.",
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "major dependency updates",
      "groupSlug": "major-dependency-updates",
      "labels": [
        "dependencies",
        "major"
      ],
      "automerge": false
    },
    {
      "description": "Never auto-merge Rust or Node runtime major updates.",
      "matchManagers": [
        "cargo",
        "npm"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    }
  ]
}
