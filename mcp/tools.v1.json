{
  "schema_version": "sourceright.mcp_tools.v1",
  "server_status": "local_stdio_server",
  "tools": [
    {
      "name": "mcp.status",
      "read_only": true,
      "input": {
        "format": "json"
      },
      "output_contract": "sourceright.mcp_status.v1"
    },
    {
      "name": "references.validate_csl",
      "read_only": true,
      "input": {
        "path": "references.csl.json"
      },
      "output_contract": "sourceright.validate_csl_output"
    },
    {
      "name": "references.report",
      "read_only": true,
      "input": {
        "workspace": ".sourceright"
      },
      "output_contract": "sourceright.reference_report.v1"
    },
    {
      "name": "references.review_queue",
      "read_only": true,
      "input": {
        "workspace": ".sourceright"
      },
      "output_contract": "sourceright.review_queue.jsonl"
    },
    {
      "name": "references.citations",
      "read_only": true,
      "input": {
        "manuscript": "manuscript.txt",
        "workspace": ".sourceright"
      },
      "output_contract": "sourceright.citation_reconciliation_report"
    },
    {
      "name": "journal.screen_submission",
      "read_only": true,
      "input": {
        "workspace": ".sourceright",
        "submission_id": "SUB-1",
        "manuscript_label": "manuscript.docx",
        "platform": "generic-webhook",
        "platform_description": "Journal screening contract label, not a live platform integration.",
        "platform_examples": [
          "generic-webhook",
          "ojs",
          "arxiv-submit-ce",
          "arxiv-submission-core"
        ],
        "platform_enum": [
          "generic-webhook",
          "generic_webhook",
          "ojs",
          "arxiv-submit-ce",
          "arxiv_submit_ce",
          "arxiv-submission-core",
          "arxiv_submission_core",
          "scholarone",
          "scholar_one",
          "editorial-manager",
          "editorial_manager",
          "ejournalpress",
          "e-journal-press",
          "e_journal_press",
          "manuscript-manager",
          "manuscript_manager"
        ]
      },
      "output_contract": "sourceright.journal_screening.v1"
    },
    {
      "name": "legal.analyze_citations",
      "read_only": true,
      "input": {
        "path": "legal-text.txt"
      },
      "output_contract": "sourceright.legal_citation_report",
      "boundary": "Draft legal citation audit only; returns jurisdiction/provider hints and review issues, not legal advice or outcome prediction."
    },
    {
      "name": "provenance.analyze_claim_sources",
      "read_only": true,
      "input": {
        "path": "document-text.txt"
      },
      "output_contract": "sourceright.provenance_report"
    },
    {
      "name": "references.policy",
      "read_only": true,
      "input": {
        "references_csl_json": "references.csl.json",
        "policy_json": "policy.json"
      },
      "output_contract": "sourceright.policy_report.v1"
    },
    {
      "name": "exports.preview",
      "read_only": true,
      "input": {
        "workspace": ".sourceright",
        "format": "ris"
      },
      "output_contract": "sourceright.export_manifest.v1"
    },
    {
      "name": "plugins.list",
      "read_only": true,
      "input": {},
      "output_contract": "sourceright.plugin_registry_report.v1"
    },
    {
      "name": "workspace.init",
      "read_only": false,
      "input": {
        "workspace": ".sourceright",
        "apply": false
      },
      "output_contract": "sourceright.mcp_write_plan.v1"
    },
    {
      "name": "review.import_decisions",
      "read_only": false,
      "input": {
        "workspace": ".sourceright",
        "apply": false,
        "decisions": []
      },
      "output_contract": "sourceright.mcp_write_plan.v1"
    },
    {
      "name": "exports.write",
      "read_only": false,
      "input": {
        "workspace": ".sourceright",
        "apply": false,
        "format": "ris"
      },
      "output_contract": "sourceright.mcp_write_plan.v1"
    }
  ]
}
