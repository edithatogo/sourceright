{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://edithatogo.github.io/sourceright/schemas/sourceright.plugin-manifest.schema.json",
  "title": "Sourceright plugin manifest",
  "type": "object",
  "properties": {
    "plugin": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "license_profile": {
          "type": "string"
        },
        "auth": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "kind",
        "version"
      ]
    }
  },
  "required": [
    "plugin"
  ],
  "additionalProperties": true
}